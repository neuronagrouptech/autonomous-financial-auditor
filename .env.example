# Autonomous Financial Auditor Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# GitHub Configuration (Required)
# =============================================================================
GITHUB_TOKEN=ghp_your_github_personal_access_token_here
GITHUB_REPO_OWNER=your-organization
GITHUB_REPO_NAME=financial-reports
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# =============================================================================
# LLM Provider Configuration
# =============================================================================

# Choose your LLM provider: bedrock, openai, or ollama
LLM_PROVIDER=bedrock

# AWS Bedrock Configuration (if using bedrock)
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_REGION=us-east-1

# OpenAI Configuration (if using openai)
OPENAI_API_KEY=sk-your_openai_api_key_here

# Ollama Configuration (if using ollama)
OLLAMA_BASE_URL=http://localhost:11434

# =============================================================================
# AWS Configuration (for Bedrock and CloudWatch)
# =============================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here

# =============================================================================
# Analysis Configuration
# =============================================================================

# Minimum confidence threshold for reporting discrepancies (0.0 - 1.0)
ANALYSIS_CONFIDENCE_THRESHOLD=0.8

# Maximum discrepancy amount to ignore (in currency units)
MAX_DISCREPANCY_AMOUNT=1000.0

# =============================================================================
# Application Configuration
# =============================================================================

# Debug mode (true/false)
DEBUG=false

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Server configuration
HOST=0.0.0.0
PORT=8000

# =============================================================================
# Monitoring Configuration
# =============================================================================

# Enable metrics collection
ENABLE_METRICS=true
METRICS_PORT=9090

# CloudWatch configuration (for AWS deployment)
CLOUDWATCH_LOG_GROUP=/aws/ecs/financial-auditor
CLOUDWATCH_METRICS_NAMESPACE=FinancialAuditor

# =============================================================================
# Document Processing Configuration
# =============================================================================

# Supported file formats (comma-separated)
SUPPORTED_FILE_FORMATS=csv,md,markdown

# File patterns for P&L documents (semicolon-separated)
PL_FILE_PATTERNS=*p&l*;*pl*;*profit*loss*;*income*statement*

# File patterns for Balance Sheet documents (semicolon-separated)
BALANCE_SHEET_PATTERNS=*balance*sheet*;*bs*;*balance*